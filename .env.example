# Copy to `.env` and fill in real values. The app reads this via app/core/config.py.

# --- Server ---
PORT=3000
ENVIRONMENT=development

# --- MongoDB (Phase 1) ---
MONGODB_URI=mongodb://localhost:27017
DB_NAME=analysisai

# --- Sanitizer service (Phase 7) ---
SANITIZER_URL=http://localhost:8000/ner

# --- OpenAI (Phase 2) ---
OPENAI_API_KEY=sk-...

# --- Per-stage models ---
BRD_AGENT_MODEL=gpt-4.1
PROMPT_AGENT_MODEL=gpt-4.1
PLANNING_AGENT_MODEL=gpt-4.1
NOTEBOOK_AGENT_MODEL=gpt-4.1
SUMMARY_AGENT_MODEL=gpt-4.1
