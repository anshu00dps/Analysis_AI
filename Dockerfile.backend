# Image for the Analysis AI backend (FastAPI + LangGraph + OpenAI + Beanie).
FROM python:3.12-slim

WORKDIR /srv

# Install dependencies first (declared in pyproject) so Docker can cache this layer
# and skip reinstalling on every code change.
COPY pyproject.toml ./
COPY app ./app
RUN pip install --no-cache-dir .

EXPOSE 3000

# Liveness check used by docker-compose `depends_on: condition: service_healthy`.
HEALTHCHECK --interval=10s --timeout=5s --retries=5 \
    CMD python -c "import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://localhost:3000/health').status==200 else 1)"

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "3000"]
